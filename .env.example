# App
APP_ENV=development
SECRET_KEY=change-me-to-random-32-chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/marketplace
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/marketplace

# Redis
REDIS_URL=redis://localhost:6379/0

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Moyasar
MOYASAR_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
MOYASAR_WEBHOOK_SECRET=your-webhook-shared-secret
MOYASAR_BASE_URL=https://api.moyasar.com/v1

# S3 / Storage
S3_BUCKET=marketplace-media
S3_REGION=me-central-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@marketplace.sa

# Platform
PLATFORM_FEE_PERCENT=1.0
